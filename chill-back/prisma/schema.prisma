// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../data/chat.db"
}

model UserIdentity {
  id           Int            @id @default(autoincrement())
  ipAddress    String         @map("ip_address")
  fingerprint  String         @unique
  userName     String?        @map("user_name")
  userAgent    String?        @map("user_agent")
  timezone     String?
  language     String?
  firstVisit   String         @map("first_visit")
  lastVisit    String         @map("last_visit")
  visitCount   Int            @default(1) @map("visit_count")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  
  // Relaciones
  sessions     UserSession[]
  conversations Conversation[]

  @@index([ipAddress])
  @@map("user_identities")
}

model Conversation {
  id             Int           @id @default(autoincrement())
  sessionId      String        @map("session_id")
  userName       String?       @map("user_name")
  userMessage    String        @map("user_message")
  botResponse    String        @map("bot_response")
  messages       String?       // JSON string con array completo de mensajes
  timestamp      String
  aiModel        String?       @map("ai_model")
  userFeedback   Boolean?      @map("user_feedback")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @default(now()) @updatedAt @map("updated_at")
  
  // Relación con UserIdentity
  userIdentityId Int?          @map("user_identity_id")
  userIdentity   UserIdentity? @relation(fields: [userIdentityId], references: [id])

  @@index([sessionId])
  @@index([userIdentityId])
  @@map("conversations")
}

model UserSession {
  id             Int           @id @default(autoincrement())
  sessionId      String        @unique @map("session_id")
  userName       String?       @map("user_name")
  lastSeen       String        @map("last_seen")
  createdAt      DateTime      @default(now()) @map("created_at")
  
  // Relación con UserIdentity
  userIdentityId Int?          @map("user_identity_id")
  userIdentity   UserIdentity? @relation(fields: [userIdentityId], references: [id])

  @@index([userIdentityId])
  @@map("user_sessions")
}

model Feedback {
  id            Int      @id @default(autoincrement())
  feedback      String   // "positive" o "negative"
  userMessage   String?  @map("user_message")
  botResponse   String?  @map("bot_response")
  userSessionId String?  @map("user_session_id")
  ip            String?
  userName      String?  @map("user_name")
  timestamp     DateTime @default(now())
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([feedback])
  @@index([userSessionId])
  @@map("feedbacks")
}

model MedicalOrder {
  id                Int       @id @default(autoincrement())
  sessionId         String    @map("session_id")
  
  // Datos del paciente
  patientDNI        String    @map("patient_dni")
  patientName       String    @map("patient_name")
  patientPhone      String?   @map("patient_phone")
  
  // Datos de la orden
  orderDate         String    @map("order_date")
  doctorName        String?   @map("doctor_name")
  doctorLicense     String?   @map("doctor_license")
  healthInsurance   String?   @map("health_insurance")
  requestedStudies  String    @map("requested_studies") // JSON string con array de estudios
  
  // Archivo
  fileName          String    @map("file_name")
  filePath          String    @map("file_path")
  fileSize          Int       @map("file_size")
  fileType          String    @map("file_type")
  
  // Validación
  validationStatus  String    @default("pending") @map("validation_status") // pending, validated, rejected
  validatedBy       String?   @map("validated_by")
  validatedAt       DateTime? @map("validated_at")
  rejectionReason   String?   @map("rejection_reason")
  
  // Metadata
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([sessionId])
  @@index([patientDNI])
  @@index([validationStatus])
  @@map("medical_orders")
}
