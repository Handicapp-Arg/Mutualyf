// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserIdentity {
  id           Int            @id @default(autoincrement())
  ipAddress    String         @map("ip_address")
  fingerprint  String         @unique
  userName     String?        @map("user_name")
  userAgent    String?        @map("user_agent")
  timezone     String?
  language     String?
  firstVisit   String         @map("first_visit")
  lastVisit    String         @map("last_visit")
  visitCount   Int            @default(1) @map("visit_count")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  
  // Relaciones
  sessions     UserSession[]
  conversations Conversation[]

  @@index([ipAddress])
  @@map("user_identities")
}

model Conversation {
  id             Int           @id @default(autoincrement())
  sessionId      String        @unique @map("session_id")
  userName       String?       @map("user_name")
  userMessage    String        @map("user_message") @db.Text
  botResponse    String        @map("bot_response") @db.Text
  messages       String?       @db.Text // JSON string con array completo de mensajes
  timestamp      String
  aiModel        String?       @map("ai_model")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @default(now()) @updatedAt @map("updated_at")
  
  // Relación con UserIdentity
  userIdentityId Int?          @map("user_identity_id")
  userIdentity   UserIdentity? @relation(fields: [userIdentityId], references: [id])

  @@index([sessionId])
  @@index([userIdentityId])
  @@map("conversations")
}

model UserSession {
  id              Int           @id @default(autoincrement())
  sessionId       String        @unique @map("session_id")
  userName        String?       @map("user_name")
  lastSeen        DateTime      @map("last_seen")
  adminControlled Boolean       @default(false) @map("admin_controlled")
  createdAt       DateTime      @default(now()) @map("created_at")

  // Relación con UserIdentity
  userIdentityId  Int?          @map("user_identity_id")
  userIdentity    UserIdentity? @relation(fields: [userIdentityId], references: [id])

  @@index([userIdentityId])
  @@index([lastSeen])
  @@map("user_sessions")
}

// ==========================================
// Modelos de Autenticación y RBAC
// ==========================================

model AdminUser {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  passwordHash String    @map("password_hash")
  fullName     String    @map("full_name")
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  roleId       Int       @map("role_id")
  role         Role      @relation(fields: [roleId], references: [id])

  @@index([email])
  @@index([roleId])
  @@map("admin_users")
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  displayName String           @map("display_name")
  description String?
  isSystem    Boolean          @default(false) @map("is_system")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  users       AdminUser[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          Int              @id @default(autoincrement())
  code        String           @unique
  displayName String           @map("display_name")
  description String?
  module      String
  createdAt   DateTime         @default(now()) @map("created_at")

  roles       RolePermission[]

  @@index([module])
  @@map("permissions")
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  granted      Boolean    @default(true)

  roleId       Int        @map("role_id")
  permissionId Int        @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ==========================================
// Archivos Adjuntos del Chat
// ==========================================

model ChatAttachment {
  id           Int      @id @default(autoincrement())
  sessionId    String   @map("session_id")
  fileName     String   @map("file_name")
  fileType     String   @map("file_type")
  fileSize     Int      @map("file_size")
  filePath     String   @map("file_path")
  description  String?  @map("description")
  uploadedBy   String   @default("user") @map("uploaded_by") // "user" | "admin"
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([sessionId])
  @@map("chat_attachments")
}

// ==========================================
// Configuración de IA
// ==========================================

model AiConfig {
  id            Int      @id @default(autoincrement())
  key           String   @unique @default("default")
  systemPrompt  String   @default("") @map("system_prompt") @db.Text
  temperature   Float    @default(0.7)
  maxTokens     Int      @default(800) @map("max_tokens")
  quickButtons  String   @default("[]") @map("quick_buttons") // JSON array de {icon, label, prompt}
  updatedAt     DateTime @updatedAt @map("updated_at")
  updatedBy     String?  @map("updated_by")

  @@map("ai_configs")
}

// ==========================================
// Quick Replies Dinámicas
// ==========================================

model QuickReply {
  id        Int      @id @default(autoincrement())
  keywords  String   @db.Text // JSON array: ["horario", "hora", "abierto"]
  response  String   @db.Text // Markdown response text
  priority  Int      @default(0)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("quick_replies")
}

// ==========================================
// RAG — Knowledge Base
// ==========================================

model KnowledgeDoc {
  id          Int       @id @default(autoincrement())
  title       String
  source      String
  category    String
  hash        String    @unique
  version     Int       @default(1)
  status      String    @default("active")
  tokensTotal Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at")
  archivedAt  DateTime? @map("archived_at")

  chunks      KnowledgeChunk[]

  @@index([category, status])
  @@index([status])
  @@map("knowledge_docs")
}

model KnowledgeChunk {
  id           Int      @id @default(autoincrement())
  docId        Int      @map("doc_id")
  doc          KnowledgeDoc @relation(fields: [docId], references: [id], onDelete: Cascade)
  ord          Int
  content      String   @db.Text
  contentClean String   @map("content_clean") @db.Text
  tokens       Int
  category     String
  embModel     String   @map("emb_model")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([docId])
  @@index([category])
  @@map("knowledge_chunks")
}

// Tabla de vectores para búsqueda KNN y FTS — gestionada por Prisma para evitar
// que db push la elimine. Los índices (IVFFlat, GIN) se crean via raw SQL en
// VectorStoreService porque Prisma no los soporta nativamente.
model KbVector {
  chunkId   Int                          @id @map("chunk_id")
  embedding Unsupported("vector(768)")?
  content   String                       @default("") @db.Text
  category  String                       @default("")

  @@map("kb_vectors")
}

model QueryCache {
  id         Int      @id @default(autoincrement())
  queryHash  String   @unique @map("query_hash")
  embedding  Bytes
  hitCount   Int      @default(1) @map("hit_count")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("query_cache")
}

model RetrievalLog {
  id           Int      @id @default(autoincrement())
  sessionId    String?  @map("session_id")
  query        String
  rewritten    String?
  category     String?
  topK         Int      @map("top_k")
  topScore     Float    @map("top_score")
  chunkIds     String   @map("chunk_ids")
  latencyMs    Int      @map("latency_ms")
  intent       String?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([sessionId])
  @@map("retrieval_logs")
}
