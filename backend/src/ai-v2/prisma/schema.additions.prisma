// Additions for ai-v2. The pgvector column is not native to Prisma; we keep it
// in the existing kb_vectors table managed via raw SQL (already used by the
// current system). The only new table is for soft feedback signals so the
// adaptive threshold can self-improve over time.

model RetrievalFeedback {
  id           Int      @id @default(autoincrement())
  logId        Int      @unique @map("log_id")
  // Soft signal: did the user continue the conversation productively (+1),
  // ask for clarification (0), or abandon / complain (-1)?
  signal       Int
  source       String   @default("implicit")   // "implicit" | "thumb" | "resolved"
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("retrieval_feedback")
}
