# CIOR Environment Variables
# Copiar este archivo como .env.local y completar con valores reales

# API Configuration
VITE_API_URL=https://api.cior.com.ar
VITE_API_VERSION=v1

# Firebase / Supabase (descomentar según implementación)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=

# Feature Flags
VITE_ENABLE_BOT=true
VITE_ENABLE_ANALYTICS=true

# External Services
VITE_MAPS_API_KEY=
